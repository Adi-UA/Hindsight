{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "backend/static",
  "functions": {
    "api/index.py": { "includeFiles": "backend/*.py" }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/index" }]
}
