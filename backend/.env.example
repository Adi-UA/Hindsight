# Copy this file to `.env` and fill in your keys. The bot defaults to paper
# trading, so it will not touch real money unless you set PAPER=false.

# Paper account (used when PAPER=true)
PAPER_ALPACA_API_KEY_ID=your-paper-key
PAPER_ALPACA_API_SECRET_KEY=your-paper-secret

# Live account (used only when PAPER=false)
ALPACA_API_KEY_ID=your-live-key
ALPACA_API_SECRET_KEY=your-live-secret

# true = paper trading (safe default); false = real money
PAPER=true

# What to trade and how
SYMBOL=VOO
STRATEGY=sma_crossover
BUY_FRACTION=0.75
SELL_FRACTION=0.10

# Runtime behaviour
TRADE_INTERVAL_DAYS=2
MAX_WAIT=300
DEBUG=false
